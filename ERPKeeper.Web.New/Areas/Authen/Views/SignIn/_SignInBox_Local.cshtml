@model ERPKeeperCore.Enterprise.Models.Security.LogInModel

<div class="flex items-center justify-center py-6 px-4 sm:px-6 lg:px-8">
    <div class="min-w-96 space-y-4 bg-white p-4 rounded-xl shadow-md">
        <div>
            <h2 class="text-center text-3xl font-extrabold text-gray-900">
                ERP Keeper
            </h2>
            <p class="mt-2 text-center text-sm text-gray-600">
                Sign in to your account
            </p>
        </div>
        <form id="LoginForm" method="post" action="/Authen/SignIn/Authen" class="mt-8 space-y-6">
            <div class="rounded shadow-sm -space-y-px">
                <div>
                    <label asp-for="Email" class="sr-only">Email address</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                            </svg>
                        </div>
                        <input asp-for="Email" type="email" required class="appearance-none rounded-none relative block w-full px-3 py-2 pl-10 border border-gray-300 placeholder-gray-200 text-gray-900 rounded-t-md focus:outline-none focus:ring-indigo-200 focus:border-indigo-200 focus:z-10 sm:text-sm" placeholder="Email address">
                    </div>
                </div>
                <div>
                    <label asp-for="Password" class="sr-only">Password</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <input asp-for="Password" type="password" required class="appearance-none rounded-none relative block w-full px-3 py-2 pl-10 border border-gray-300 placeholder-gray-200 text-gray-900 rounded-b-md focus:outline-none focus:ring-indigo-200 focus:border-indigo-200 focus:z-10 sm:text-sm" placeholder="Password">
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-between">
                <div class="text-sm flex">
                    <input type="checkbox" id="RememberEmail" name="RememberEmail" class="h-4 w-4 text-indigo-600 focus:ring-indigo-200 border-gray-300 rounded">
                    <label for="RememberEmail" class="ml-2 block text-sm text-gray-900">
                        Remember me
                    </label>
                </div>
             
                <div class="text-sm">
                    <a href="#" class="font-medium text-indigo-600 hover:text-indigo-200">
                        Forgot password?
                    </a>
                </div>
            </div>

            <div>
                <button type="button" onclick="SubmitLogin()" class="group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-200">
                    <span class="absolute left-0 inset-y-0 flex items-center pl-3">
                        <svg class="h-5 w-5 text-indigo-500 group-hover:text-indigo-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                        </svg>
                    </span>
                    <span class="text-white">Sign in</span>
                   
                </button>
            </div>

            <div class="text-sm">
                <a href="https://erp-tec.advancemaker.com" class="font-medium text-indigo-600 hover:text-indigo-200">
                    TEC
                </a> |
                <a href="https://erp-bit.advancemaker.com/privacy-policy" class="font-medium text-indigo-600 hover:text-indigo-200">
                    BIT
                </a>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="mt-2 text-center text-sm text-red-600">
                    @Model.ErrorMessage
                </div>
            }
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}

<script>
    function SubmitLogin() {
        const rememberEmail = document.getElementById("RememberEmail").checked;
        const emailInput = document.getElementById("Email");
        
        if (rememberEmail) {
            setCookie("LoginEmail", emailInput.value, 30); // Store for 30 days
            setCookie("RememberEmail", "true", 30);
        } else {
            deleteCookie("LoginEmail");
            deleteCookie("RememberEmail");
        }
        
        document.getElementById("LoginForm").submit();
    }

    function setCookie(name, value, days) {
        const date = new Date();
        date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
        const expires = "expires=" + date.toUTCString();
        document.cookie = name + "=" + encodeURIComponent(value) + ";" + expires + ";path=/";
    }

    function getCookie(name) {
        const nameEQ = name + "=";
        const cookies = document.cookie.split(';');
        for (let i = 0; i < cookies.length; i++) {
            let cookie = cookies[i].trim();
            if (cookie.indexOf(nameEQ) === 0) {
                return decodeURIComponent(cookie.substring(nameEQ.length));
            }
        }
        return null;
    }

    function deleteCookie(name) {
        setCookie(name, "", -1);
    }

    // Load saved email on page load
    document.addEventListener('DOMContentLoaded', function() {
        const savedEmail = getCookie("LoginEmail");
        const rememberEmail = getCookie("RememberEmail");
        
        if (savedEmail) {
            document.getElementById("Email").value = savedEmail;
        }
        
        if (rememberEmail === "true") {
            document.getElementById("RememberEmail").checked = true;
        }
    });
</script>