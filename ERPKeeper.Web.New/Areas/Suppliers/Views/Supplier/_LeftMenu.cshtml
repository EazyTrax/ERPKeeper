@model ERPKeeperCore.Enterprise.Models.Suppliers.Supplier

<div class="lh-120">
    <a href="/Suppliers">Suppliers</a>
</div>
<div class="lh-120">
    <a href="/Suppliers/Suppliers/@Model.Id">@Model.Profile.Name</a>
</div>
<div class="lh-120">
    @await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Home", Url = $"/Suppliers/Suppliers/{Model.Id}" })
    @await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Purchases", Url = $"/Suppliers/Suppliers/{Model.Id}/Purchases", Count = Organization.ErpCOREDBContext.Purchases.Where(s => s.SupplierId == Model.Id).Count() })
    @await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 1, DisplayName = "Quote", Url = $"/Suppliers/Suppliers/{Model.Id}/PurchaseQuotes", Count = Organization.ErpCOREDBContext.PurchaseQuotes.Where(s => s.SupplierId == Model.Id).Count() })
    @await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Payments", Url = $"/Suppliers/Suppliers/{Model.Id}/ReceivePayments", Count = Organization.ErpCOREDBContext.SupplierPayments.Where(s => s.Purchase.SupplierId == Model.Id).Count() })
    @await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Items", Url = $"/Suppliers/Suppliers/{Model.Id}/Items" })
</div>
