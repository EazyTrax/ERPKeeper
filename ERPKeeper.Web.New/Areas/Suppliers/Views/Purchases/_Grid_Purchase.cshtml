
<div id="treeList" class="">
    @(Html.DevExtreme().DataGrid<ERPKeeperCore.Enterprise.Models.Suppliers.Purchase>()
            .ID("gridList")
            .DataSource(d => d.RemoteController().Key("Id")
            .LoadUrl($"/API/Suppliers/Purchases/All")
            .InsertUrl($"/API/Suppliers/Purchases/Insert")
            .UpdateUrl($"/API/Suppliers/Purchases/Update")
            .UpdateMethod("Post")
            .InsertMethod("Post"))

            .RowAlternationEnabled(true).AllowColumnReordering(true)
            .KeyExpr("Id")
            .Editing(editing => editing.Mode(GridEditMode.Batch).AllowAdding(IsOnEditMode).AllowUpdating(IsOnEditMode).UseIcons(true))
            .StateStoring(s => s.Enabled(true).Type(StateStoringType.LocalStorage).StorageKey("Purchases" ))
            .ShowRowLines(true)
            .ShowBorders(false)
            .AllowColumnResizing(true).AllowColumnReordering(true)
            .Paging(paging => paging.PageSize(300))
            .HeaderFilter(headerFilter => headerFilter.Visible(true).Search(s => s.Enabled(true)))
            .FilterRow(filterRow => filterRow.Visible(true).ApplyFilter(GridApplyFilterMode.Auto))

            .ColumnAutoWidth(false)
            .ColumnChooser(columnChooser => columnChooser.Enabled(true))
            .Columns(columns =>
            {
                columns.AddFor(m => m.AgeInDays).Width(60).AllowEditing(false).ShowInColumnChooser(true)
            .CellTemplate(new JS("function(cellElement, cellInfo) { $('<span>').addClass('text-' + cellInfo.data.AgeColor + '-400').text(cellInfo.data.AgeInDays).appendTo(cellElement); }"));


                columns.AddFor(m => m.Date).SortOrder(SortOrder.Desc).SortIndex(1).Width(130);

                columns.AddFor(m => m.Status).AllowEditing(false).Width(80).Lookup(lookup => lookup
            .DataSource(Html.GetEnumSelectList<ERPKeeperCore.Enterprise.Models.Suppliers.Enums.PurchaseStatus>().Select(i => new { Value = int.Parse(i.Value), Text = i.Text }).ToList())
            .DisplayExpr("Text")
            .ValueExpr("Value")
            );

                    columns.AddFor(m => m.Name)
        .AllowEditing(false)
        .Visible(false)
            .ShowInColumnChooser(true)
    .Width(150)
    .CellTemplate(new JS("function(cellElement, cellInfo) { $('<a>').attr('href', '/Suppliers/Purchases/' + cellInfo.data.Id + '/').text(cellInfo.data.Name).appendTo(cellElement); }"));


                columns.AddFor(m => m.SupplierId)
                .Lookup(lookup => lookup
            .DataSource(Organization.ErpCOREDBContext.Suppliers.Select(i => new { Value = i.Id, Text = i.Profile.Name }).ToList())
            .DisplayExpr("Text")
            .ValueExpr("Value"))
            .AllowEditing(IsOnEditMode)
            .MinWidth(200)
            .CellTemplate(new JS("function(cellElement, cellInfo) { $('<a>').attr('href', '/Suppliers/Suppliers/' + cellInfo.data.SupplierId + '/').text(cellInfo.displayValue).appendTo(cellElement); }"));


                columns.AddFor(m => m.Reference)
                .Width(180)
                        .CellTemplate(new JS("function(cellElement, cellInfo) { $('<a>').attr('href', '/Suppliers/Purchases/' + cellInfo.data.Id + '/').text(cellInfo.data.Reference).appendTo(cellElement); }")); ;

        

                columns.AddFor(m => m.Total).Width(130)
                .AllowEditing(false)
                .Format("#,##0.00");

                columns.AddFor(m => m.Tax).Width(130)
                .AllowEditing(false)
                .Format("#,##0.00");



                columns.AddFor(m => m.TaxCodeId)
                    .Lookup(lookup => lookup
                    .DataSource(Organization.ErpCOREDBContext.TaxCodes.Select(i => new { Value = i.Id, Text = i.Name }).ToList())
                    .DisplayExpr("Text")
                    .ValueExpr("Value")
                    .AllowClearing(true))
                    .HeaderCellTemplate(new JS("function() { return 'TaxCode'; }"))
                    .CellTemplate(new JS("function(cellElement, cellInfo) { $('<a>').attr('href', '/Taxes/TaxCodes/' + cellInfo.data.TaxCodeId + '/').text(cellInfo.displayValue).appendTo(cellElement); }"));


                columns.AddFor(m => m.TaxPeriodId).Lookup(lookup => lookup
            .DataSource(Organization.ErpCOREDBContext.TaxPeriods.Select(i => new { Value = i.Id, Text = i.Name }).ToList())
            .DisplayExpr("Text")
            .ValueExpr("Value"))
            .Width(150)
            .ShowInColumnChooser(true)
            .HeaderCellTemplate(new JS("function() { return 'TaxPeriod'; }"))
        .CellTemplate(new JS("function(cellElement, cellInfo) { $('<a>').attr('href', '/Taxes/TaxPeriods/' + cellInfo.data.TaxPeriodId + '/').text(cellInfo.displayValue).appendTo(cellElement); }"));

                columns.AddFor(m => m.ExpenseAccountId)
            .Lookup(lookup => lookup.DataSource(Organization.ChartOfAccount.AssetsAndExpenses.Select(t => new { t.Id, t.Name }).OrderBy(t => t.Name).ToList()).DisplayExpr("Name").ValueExpr("Id"))
            .Width(150)
            .HeaderCellTemplate(new JS("function() { return 'Expense'; }"))
        .CellTemplate(new JS("function(cellElement, cellInfo) { $('<a>').attr('href', '/Accounting/Accounts/' + cellInfo.data.ExpenseAccountId + '/').text(cellInfo.displayValue).appendTo(cellElement); }"));
          
        columns.AddFor(m => m.ProjectId)
            .Lookup(lookup => lookup
            .DataSource(Organization.ErpCOREDBContext.Projects.Select(i => new { Value = i.Id, Text = i.Name }).ToList())
            .DisplayExpr("Text")
            .ValueExpr("Value"))
            .Width(150)
            .Visible(false)
            .ShowInColumnChooser(true)
            .HeaderCellTemplate(new JS("function() { return 'Project'; }"))
        .CellTemplate(new JS("function(cellElement, cellInfo) { $('<a>').attr('href', '/Projects/' + cellInfo.data.ProjectId + '/').text(cellInfo.displayValue).appendTo(cellElement); }"));





                columns.AddFor(m => m.IsPosted).AllowEditing(false).Width(30).HeaderCellTemplate(new JS("function() { return ' '; }")).CellTemplate(new JS("function(cellElement, cellInfo) { $('<i>').addClass('fas fa-fingerprint text-' + cellInfo.data.IsPosted).appendTo(cellElement); }"));

            })
        .Summary(s =>
        s.TotalItems(items =>
        {
            items.AddFor(m => m.LinesTotalAfterDiscount).SummaryType(SummaryType.Sum).DisplayFormat("{0}").ValueFormat("#,##0.00");
            items.AddFor(m => m.Total).SummaryType(SummaryType.Sum).DisplayFormat("{0}").ValueFormat("#,##0.00");
        }))
         .OnInitNewRow("onInitNewRow")
            )
</div>

<script>
    function onInitNewRow(e) {
        const today = new Date();
        e.data.Date = today;
        e.data.Status = 0;
    }
</script>
