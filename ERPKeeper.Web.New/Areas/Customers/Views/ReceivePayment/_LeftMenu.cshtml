@model ERPKeeperCore.Enterprise.Models.Customers.ReceivePayment

<div class="lh-120">
    <a href="/Customers/Customers">Customers</a><br />
    <a href="/Customers/ReceivePayments">ReceivePayments</a><br />
    <a href="/Customers/ReceivePayments/@Model.Id">@Model.Sale.Name.Replace("SL", "RP")</a>
</div>

<div class="lh-120">
    @await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Detail", Url = $"/Customers/ReceivePayments/{Model.Id}" })
    @await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = $"Sale: {Model.Sale.Name}", Url = $"/Customers/Sales/{Model.SaleId}" })
    @await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Documents", Url = $"/Customers/ReceivePayments/{Model.Id}/Documents" })
</div>
<div class="lh-120">
    @await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Export", Url = $"/Customers/ReceivePayments/{Model.Id}/Export" })
</div>