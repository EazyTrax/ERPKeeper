<!-- Add Work Button -->
<button type="button" class="btn btn-primary btn-sm" data-bs-toggle="offcanvas" data-bs-target="#addWorkDrawer" title="Add Work Record" onclick="console.log('Button clicked');">
    <i class="fas fa-clock"></i> Add Work Record
</button>

<!-- Drawer/Offcanvas -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="addWorkDrawer" aria-labelledby="addWorkDrawerLabel" style="width: 400px;">
    <div class="offcanvas-header bg-primary text-white">
        <h5 class="offcanvas-title" id="addWorkDrawerLabel">
            <i class="fas fa-clock me-2"></i>Add New Work Record
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <form id="addWorkForm" method="post" action="@Url.Action("Create", "WorkRecords")">

            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label for="workAmount" class="form-label">Work Duration</label>
                <select class="form-select" id="workAmount" name="Amount" required>
                    <option value="">Select Duration</option>
                    <option value="0" selected>Full Day</option>
                    <option value="1">Half Day</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="recordDate" class="form-label">Date</label>
                <input type="date" class="form-control" id="recordDate" name="RecordDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
            </div>

            <div class="mb-3">
                <label for="notes" class="form-label">Notes (Optional)</label>
                <textarea class="form-control" id="notes" name="Notes" rows="3" placeholder="e.g., Project details, tasks completed..."></textarea>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Submit Work Record
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    console.log('AddWorkWidget loaded');
    console.log('Bootstrap available:', typeof bootstrap !== 'undefined');
</script>

