
@{
    var employeePaymentPeriods = Organization.ErpCOREDBContext.EmployeePaymentPeriods.ToList();
}

<div id="treeList" class="">

    @(Html.DevExtreme().DataGrid<ERPKeeperCore.Enterprise.Models.Employees.EmployeePayment>()
        .ID("gridList")
        .DataSource(d => d.RemoteController().Key("Id")
        .LoadUrl($"/API/HR/Employees/{EmployeeId}/EmployeePayments/All")
        .InsertUrl($"/API/HR/Employees/{EmployeeId}/EmployeePayments/Insert")
        .UpdateUrl($"/API/HR/Employees/{EmployeeId}/EmployeePayments/Update").UpdateMethod("Post")
        .DeleteUrl($"/API/HR/Employees/{EmployeeId}/EmployeePayments/Delete").DeleteMethod("Post")
        )
        .KeyExpr("Id")
        .RowAlternationEnabled(true).AllowColumnReordering(true)
        .ShowRowLines(true)
        .ShowBorders(false)
        .Width("100%")
        .Paging(paging => paging.PageSize(100))
        .StateStoring(s => s.Enabled(true).Type(StateStoringType.SessionStorage).StorageKey("EmployeePayments"))
        .ColumnChooser(columnChooser => columnChooser.Enabled(true))    
        .AllowColumnResizing(true).AllowColumnReordering(true)
        .HeaderFilter(headerFilter => headerFilter.Visible(true).Search(s=>s.Enabled(true)))
        .FilterRow(filterRow => filterRow
        .Visible(true)
        .ApplyFilter(GridApplyFilterMode.Auto)
        )
        .ColumnAutoWidth(false)
        @*.AutoExpandAll(true)*@
        .RowDragging(rd => rd
        .AllowDropInsideItem(false)
        .AllowReordering(false)
        @*.OnDragChange("onDragChange")
    .OnDragEnd("onDragEnd")
    .ShowDragIcons(false)*@
        )
            .Columns(columns =>
            {

                columns.AddFor(m => m.Name)
            .CellTemplate(new JS("function(container, options) { container.append($('<a>').attr('href', '/HR/EmployeePayments/' + options.data.Id + '/').text(options.value)); }"));



                columns.AddFor(m => m.EmployeePaymentPeriodId).Width(130)
            .Lookup(lookup => lookup
            .DataSource(employeePaymentPeriods.Select(i => new { Value = i.Id, Name = i.Name }).ToList())
            .DisplayExpr("Name")
            .ValueExpr("Value"))
            .CalculateSortValue("Name")
            .HeaderCellTemplate(@<text>Period</text>)
        .CellTemplate(new JS("function(container, options) { container.append($('<a>').attr('href', '/HR/EmployeePaymentPeriods/' + options.data.EmployeePaymentPeriodId + '/').text(options.text)); }"));


                columns.AddFor(m => m.EmployeePaymentPeriodId).Width(130)
            .AllowEditing(false)
    .HeaderCellTemplate(@<text>Date</text>
    )
    .Lookup(lookup => lookup
    .DataSource(employeePaymentPeriods.Select(i => new { Value = i.Id, Date = i.Date }).ToList())
    .DisplayExpr("Date")
    .ValueExpr("Value"));

        columns.AddFor(m => m.Note);

                columns.AddFor(m => m.TotalEarning).Width(150).AllowEditing(false).Format("#,##0.00").HeaderCellTemplate(@<text>Earning</text>);
            columns.AddFor(m => m.TotalDeduction).Width(150).AllowEditing(false).Format("#,##0.00").HeaderCellTemplate(@<text>Deduction</text>);




                columns.AddFor(m => m.IsPosted)
            .AllowEditing(false).Width(30)
            .HeaderCellTemplate(@<text> </text>)
            .CellTemplate(new JS("function(container, options) { container.append($('<i>').addClass('fas fa-fingerprint text-' + options.data.IsPosted)); }"));






                })
                .Summary(s =>
            s.TotalItems(items =>{

                items.AddFor(m => m.TotalEarning).SummaryType(SummaryType.Sum).DisplayFormat("{0}").ValueFormat("#,##0.00");
                items.AddFor(m => m.TotalDeduction).SummaryType(SummaryType.Sum).DisplayFormat("{0}").ValueFormat("#,##0.00");
            })
            .GroupItems(items =>
            {
            items.AddFor(m => m.TotalEarning).SummaryType(SummaryType.Sum).DisplayFormat("{0}").ValueFormat("#,##0.00").ShowInGroupFooter(true);
            items.AddFor(m => m.TotalDeduction).SummaryType(SummaryType.Sum).DisplayFormat("{0}").ValueFormat("#,##0.00").ShowInGroupFooter(true);

        }))
        )
</div>


