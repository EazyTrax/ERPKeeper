@{
    var totalReceived = Employee?.EmployeePayments?.Sum(x => x.TotalPayment) ?? 0;
    var thisYearTotal = Employee?.EmployeePayments?.Where(x => x.EmployeePaymentPeriod.Date.Year == DateTime.Now.Year).Sum(x => x.TotalPayment) ?? 0;
    var paymentsCount = Employee?.EmployeePayments?.Count() ?? 0;
    var thisYearPaymentsCount = Employee?.EmployeePayments?.Where(x => x.EmployeePaymentPeriod.Date.Year == DateTime.Now.Year).Count() ?? 0;
}

<!-- Compensation Summary Widget -->
<div class="bg-white rounded-lg shadow p-4 mb-4">
    <h3 class="font-bold mb-4 text-lg">Compensation Summary</h3>
    
  

    <!-- This Year Total -->
    <div>
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-600 text-sm mb-1">This Year (@DateTime.Now.Year)</p>
                <h4 class="text-xl font-bold text-green-600">@thisYearTotal.ToString("N2")</h4>
                <p class="text-gray-500 text-xs mt-1">@thisYearPaymentsCount payment(s)</p>
            </div>
            <div class="text-green-500">
                <i class="fas fa-calendar-alt fa-2x"></i>
            </div>
        </div>
    </div>
</div>
