@{
    var leaveBalance = Employee?.EmployeeLeaveRecords?.Where(x => x.RecordDate.Year == DateTime.Now.Year).Count() ?? 0;
    var pendingLeaves = Employee?.EmployeeLeaveRecords?.Where(x => x.Status == ERPKeeperCore.Enterprise.Models.Employees.LeaveAttendanceStatus.Pending).Count() ?? 0;
    var approvedLeaves = Employee?.EmployeeLeaveRecords?.Where(x => x.Status == ERPKeeperCore.Enterprise.Models.Employees.LeaveAttendanceStatus.Approved && x.RecordDate.Year == DateTime.Now.Year).Count() ?? 0;
}

<!-- Quick Stats Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-lg shadow p-4 border-l-4 border-blue-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-600 text-sm">Leave Taken This Year</p>
                <h3 class="text-2xl font-bold text-blue-600">@approvedLeaves</h3>
            </div>
            <div class="text-blue-500">
                <i class="fas fa-calendar-check fa-2x"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-4 border-l-4 border-yellow-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-600 text-sm">Pending Requests</p>
                <h3 class="text-2xl font-bold text-yellow-600">@pendingLeaves</h3>
            </div>
            <div class="text-yellow-500">
                <i class="fas fa-clock fa-2x"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-4 border-l-4 border-green-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-600 text-sm">Total Leave Records</p>
                <h3 class="text-2xl font-bold text-green-600">@leaveBalance</h3>
            </div>
            <div class="text-green-500">
                <i class="fas fa-list fa-2x"></i>
            </div>
        </div>
    </div>
</div>
