@{
    var leavesTaken = Employee?.EmployeeLeaveRecords?.Where(x => x.Status == ERPKeeperCore.Enterprise.Models.Employees.LeaveAttendanceStatus.Approved && x.RecordDate.Year == DateTime.Now.Year).Count() ?? 0;
    var pendingLeaves = Employee?.EmployeeLeaveRecords?.Where(x => x.Status == ERPKeeperCore.Enterprise.Models.Employees.LeaveAttendanceStatus.Pending).Count() ?? 0;
    var certificatesCount = Employee?.CertificateAndLicenses?.Count() ?? 0;
    var developmentCourses = Employee?.DevelopmentCourses?.Count() ?? 0;
}

<!-- Dashboard Overview Stats -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg shadow p-4 border-l-4 border-blue-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-600 text-sm">Leaves Taken</p>
                <h3 class="text-2xl font-bold text-blue-600">@leavesTaken</h3>
                <p class="text-xs text-gray-500">This Year</p>
            </div>
            <div class="text-blue-500">
                <i class="fas fa-calendar-check fa-2x"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-4 border-l-4 border-yellow-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-600 text-sm">Pending Requests</p>
                <h3 class="text-2xl font-bold text-yellow-600">@pendingLeaves</h3>
                <p class="text-xs text-gray-500">Awaiting Approval</p>
            </div>
            <div class="text-yellow-500">
                <i class="fas fa-clock fa-2x"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-4 border-l-4 border-green-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-600 text-sm">Training Courses</p>
                <h3 class="text-2xl font-bold text-green-600">@developmentCourses</h3>
                <p class="text-xs text-gray-500">Completed</p>
            </div>
            <div class="text-green-500">
                <i class="fas fa-graduation-cap fa-2x"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-4 border-l-4 border-purple-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-600 text-sm">Certifications</p>
                <h3 class="text-2xl font-bold text-purple-600">@certificatesCount</h3>
                <p class="text-xs text-gray-500">Active Certs</p>
            </div>
            <div class="text-purple-500">
                <i class="fas fa-certificate fa-2x"></i>
            </div>
        </div>
    </div>
</div>
