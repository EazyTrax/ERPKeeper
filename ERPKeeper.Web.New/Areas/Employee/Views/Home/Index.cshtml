



<div id="MainContent" class="flex mh-100vh">
    <div class="col col-center pl-0">
        <div class="p-4">
            <!-- Welcome Section -->
            <div class="mb-4">
                <h1 class="text-2xl font-bold mb-2">Welcome, @Employee.Profile.Name</h1>
                <p class="text-gray-600">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
            </div>

            <partial name="_QuickStatsWidget" />
            
            <partial name="_RecentLeaveRecordsWidget" />

            <partial name="_QuickActionsWidget" />
        </div>
    </div>
    <div class="col-300px col-right">
        <div class="p-4">

            <partial name="_ProfileSummaryWidget" />
            <partial name="/areas/employee/views/compensations/_CompensationSummaryWidgetTotal.cshtml" />


            <partial name="_AnnouncementsWidget" />
        </div>
    </div>
</div>


