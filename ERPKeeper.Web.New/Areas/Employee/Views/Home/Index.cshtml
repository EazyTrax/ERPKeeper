





<div id="MainContent" class="flex mh-100vh">
    <div class="col col-center pl-0">
        <div class="p-4">
            <!-- Welcome Section -->
            <div class="mb-4">
                <h1 class="text-2xl font-bold mb-2">Welcome, @Employee.Profile.Name</h1>
                <p class="text-gray-600">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
            </div>

            <!-- Dashboard Overview Stats -->
            <partial name="_DashboardStatsWidget" />
            
            <!-- Leave Balance & Recent Leaves -->
            <partial name="_LeaveBalanceWidget" />

            <!-- Certifications & Licenses -->
            <partial name="_CertificationsWidget" />
            
            <!-- Training & Development -->
            <partial name="_WorkRecordsSummaryWidget" />

            <!-- Quick Actions -->
            <partial name="_QuickActionsWidget" />
        </div>
    </div>
    <div class="col-300px col-right">
        <div class="p-4">
            <!-- Profile Summary -->
            <partial name="_ProfileSummaryWidget" />
            
            <!-- Compensation Summary -->
            <partial name="/areas/employee/views/compensations/_CompensationSummaryWidgetTotal.cshtml" />

            <!-- Upcoming Events & Reminders -->
            <partial name="_UpcomingEventsWidget" />

            <!-- Announcements -->
            <partial name="_AnnouncementsWidget" />
        </div>
    </div>
</div>


