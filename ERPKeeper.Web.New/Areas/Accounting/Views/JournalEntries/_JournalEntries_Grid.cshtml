<div class="mb-2 border-top">
    @(Html.DevExtreme().DataGrid<ERPKeeperCore.Enterprise.Models.Accounting.JournalEntry>()
        .ID("AssetsTreeList")
        .KeyExpr("Id")
        .DataSource(d => d.RemoteController()
        .Key("Id")
        .LoadUrl($"/api/Accounting/JournalEntries/All")
        .InsertUrl($"/api/Accounting/JournalEntries/Insert")
        .UpdateUrl($"/api/Accounting/JournalEntries/Update")
        .UpdateMethod("Post"))
        .AllowColumnReordering(true)
        .RowAlternationEnabled(true).AllowColumnReordering(true).ShowRowLines(true).HoverStateEnabled(true)
        .ShowColumnLines(true)
        .ShowBorders(false)
        .HeaderFilter(headerFilter => headerFilter.Visible(true).Search(s=>s.Enabled(true)))
        .FilterRow(filterRow => filterRow.Visible(true).ApplyFilter(GridApplyFilterMode.Auto))
        .ColumnAutoWidth(false)
        .Paging(pagging => pagging.PageSize(100))
        .GroupPanel(gp => gp.Visible(true))
         .Editing(editing => editing.Mode(GridEditMode.Row).AllowUpdating(IsOnEditMode).AllowAdding(IsOnEditMode).UseIcons(true))
        @*  .AllowColumnResizing(true).AllowColumnReordering(true)*@

        .Columns(columns =>
        {
                columns.AddFor(m => m.Date).Width(130).Format(Format.ShortDate);
   columns.AddFor(m => m.Name)
                .AllowEditing(false)
                .Width(130)
                .SortOrder(SortOrder.Desc)
                .CellTemplate(new JS("function(container, options) { container.append('<div><a href=\"/Accounting/JournalEntries/' + options.data.Id + '/\">' + options.value + '</a></div>'); }"));
                
                columns.AddFor(m => m.Memo)
                .SortOrder(SortOrder.Desc)
                .CellTemplate(new JS("function(container, options) { container.append('<div><a href=\"/Accounting/JournalEntries/' + options.data.Id + '/\">' + options.value + '</a></div>'); }"));
                
                columns.AddFor(m => m.JournalEntryTypeId)
                    .Lookup(lookup => lookup.DataSource(Organization.ErpCOREDBContext.JournalEntryTypes.Select(t => new { t.Id, t.Name }).OrderBy(t => t.Name).ToList()).DisplayExpr("Name").ValueExpr("Id"))
                    .HeaderCellTemplate(@<text>Type</text>)
                    .CellTemplate(new JS("function(container, options) { container.append('<a href=\"/Accounting/JournalEntryTypes/' + options.data.JournalEntryTypeId + '/\">' + options.text + '</a>'); }"));

             
                columns.AddFor(m => m.Debit)
                .AllowEditing(false)
                .Width(130)
                .Format("#,##0.00");
                
                columns.AddFor(m => m.Credit)
                .AllowEditing(false)
                .Width(130)
                .Format("#,##0.00");
                
                columns.AddFor(m => m.IsPosted)
                .AllowEditing(false)
                .Width(30)
                .HeaderCellTemplate(@<text> </text>).CellTemplate(new JS("function(container, options) { container.append('<i class=\"fas fa-fingerprint text-' + options.data.IsPosted + '\"></i>'); }"));
        })
        )
</div>