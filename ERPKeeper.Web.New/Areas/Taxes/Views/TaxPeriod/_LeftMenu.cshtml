@model ERPKeeperCore.Enterprise.Models.Taxes.TaxPeriod



@await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Taxes", Url = "/Taxes" })
@await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "TaxPeriods", Url = "/Taxes/TaxPeriods" })
@await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = Model.Name, Url = $"/Taxes/TaxPeriods/{Model.Id}" })

@await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Home", Url = $"/Taxes/TaxPeriods/{Model.Id}" })
@await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Sales", Url = $"/Taxes/TaxPeriods/{Model.Id}/Sales", Count = Model.SalesCount })
@await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Purchase", Url = $"/Taxes/TaxPeriods/{Model.Id}/Purchases", Count = Model.PurchasesCount })
@await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "AutoAssign (ThisMonth)", Url = $"/Taxes/TaxPeriods/{Model.Id}/AutoAssign" })
@await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "AutoAssign (PreviusMonth)", Url = $"/Taxes/TaxPeriods/{Model.Id}/AutoAssign?IsHistoryAssign=True" })
@await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Export", Url = $"/Taxes/TaxPeriods/{Model.Id}/Export", Count = Model.PurchasesCount })
