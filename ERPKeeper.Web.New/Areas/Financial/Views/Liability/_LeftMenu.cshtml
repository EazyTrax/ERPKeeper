@model ERPKeeperCore.Enterprise.Models.Accounting.Account


@await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Financial", Url = "/Financial" })
@await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = "Liabilities", Url = "/Financial/Liabilities" })
@await Html.PartialAsync("_MenuTemplate", new ERPKeeper.Web.New.Models.MenuTemplateModel { Level = 0, DisplayName = Model.Name, Url = $"/Financial/Liabilities/{Model.Id}" })

@await Html.PartialAsync("_MenuTemplate", new { level = 0, displayName = "Home", url = $"/Financial/Liabilities/{Model.Id}", count = Organization.FundTransfers.Count() })
@await Html.PartialAsync("_MenuTemplate", new { level = 0, displayName = "Balances", url = $"/Financial/Liabilities/{Model.Id}/Balances" })
@await Html.PartialAsync("_MenuTemplate", new { level = 0, displayName = "Payments", url = $"/Financial/Liabilities/{Model.Id}/Payments" })
