    @await Html.PartialAsync("_MenuTemplate", new MenuTemplateModel { Level = 0, DisplayName = "Loans", Url = "/Financial/Loans", Count = Organization.ErpCOREDBContext.Loans.Count() })
</div>

<div class="lh-120">
    @await Html.PartialAsync("_MenuTemplate", new MenuTemplateModel { Level = 0, DisplayName = "Retention Types", Url = "/Financial/RetentionTypes", Count = Organization.ErpCOREDBContext.RetentionTypes.Count() })
