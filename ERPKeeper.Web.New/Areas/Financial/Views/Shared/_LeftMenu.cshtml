<div class="lh-120">
       @await Html.PartialAsync("_MenuTemplate", new MenuTemplateModel { Level = 0, DisplayName = "Financial", Url = "/Financial" })
</div>

<div class="lh-120">
    @await Html.PartialAsync("_MenuTemplate", new MenuTemplateModel { Level = 0, DisplayName = "FundTransfers", Url = "/Financial/FundTransfers", Count = Organization.FundTransfers.Count() })
