
<style>
    .dx-treelist .dx-flex > td {
        padding: 2px !important;
    }
</style>

<div id="treeList" class="">
    @(Html.DevExtreme().DataGrid<ERPKeeperCore.Enterprise.Models.Items.Item>()
            .ID("gridList")
            .DataSource(d => d.RemoteController().Key("Id")
            .LoadUrl($"/api/Products/Items/All")
            .InsertUrl($"/api/Products/Items/Insert")
            .UpdateUrl($"/api/Products/Items/Update")
            .UpdateMethod("Post"))
            .ShowRowLines(true)
            .ShowBorders(false)
            .Editing(editing => editing.Mode(GridEditMode.Popup).AllowUpdating(true).AllowAdding(true))
            .StateStoring(s => s.Enabled(true).Type(StateStoringType.LocalStorage).StorageKey("Products"))
            .AllowColumnResizing(true).AllowColumnReordering(true)
            .AllowColumnReordering(true)
            .Paging(paging => paging.PageSize(100))
            .FilterRow(fp => fp.Visible(true))
            .GroupPanel(Panel => Panel.Visible(true))
            .HeaderFilter(headerFilter => headerFilter.Visible(true).Search(s=>s.Enabled(true)))
            .ColumnChooser(Panel => Panel.Enabled(true))
            .ColumnAutoWidth(false)
            .RowAlternationEnabled(true).AllowColumnReordering(true)
            .Columns(columns =>
            {
                columns.AddFor(m => m.BrandId).Width(150)
            .CellTemplate(new JS("function(container, options) { $('<a>').attr('href', '/Products/Brands/' + options.data.BrandId + '/').text(options.displayValue).appendTo(container); }"))
                .HeaderCellTemplate(@<text>Brand</text>)
            .Lookup(lookup => lookup
            .DataSource(Organization.ErpCOREDBContext.Brands.Select(t => new { t.Id, t.Name }).ToList())
            .DisplayExpr("Name")
            .ValueExpr("Id")
            );

                columns.Add().DataField("PartNumber")
            .SortOrder(SortOrder.Asc)
            .SortIndex(1)
            .MinWidth(200)
            .CellTemplate(new JS("function(container, options) { $('<a>').attr('href', '/Products/Items/' + options.data.Id + '/').append($('<span>').text(options.data.PartNumber)).appendTo(container); }"));

                columns.AddFor(m => m.Description)
                .FormItem(i => i.Editor(e => e.TextArea().MinHeight(300)))
                .CellTemplate(new JS("function(container, options) { $('<a>').attr('href', '/Products/Items/' + options.data.Id + '/').text(options.data.Description).appendTo(container); }"));
          

                columns.AddFor(m => m.ItemType)
                .Width(130)
                .SortOrder(SortOrder.Asc)
                .SortIndex(2)
                .HeaderCellTemplate("Type")
                .Lookup(lookup => lookup
                    .DataSource(Html.GetEnumSelectList<ERPKeeperCore.Enterprise.Models.Items.Enums.ItemTypes>().Select(i => new { Value = int.Parse(i.Value), Text = i.Text }).ToList())
                    .DisplayExpr("Text")
                    .ValueExpr("Value")
                    );

                columns.AddFor(m => m.ItemGroupId).Width(150)
            .CellTemplate(new JS("function(container, options) { $('<a>').attr('href', '/Products/ItemGroups/' + options.data.ItemGroupId + '/').text(options.displayValue).appendTo(container); }"))
        .HeaderCellTemplate(@<text>Group</text>)
        .Lookup(lookup => lookup
        .DataSource(Organization.ErpCOREDBContext.ItemGroups.Select(t => new { t.Id, t.Name }).ToList())
        .DisplayExpr("Name")
        .ValueExpr("Id")
        );




                columns.AddFor(m => m.OnlineSale).Visible(false).Width(60).HeaderCellTemplate(@<text>Online</text>);
            columns.AddFor(m => m.SoldAmount).AllowEditing(false).Width(60).HeaderCellTemplate(@<text>Sold</text>);
                columns.AddFor(m => m.AmountOnHand).AllowEditing(false).AllowEditing(false).Width(80).HeaderCellTemplate(@<text>Stock</text>);
               
                columns.Add().DataField("SalePrice").Width(130).Format("#,##0.00").HeaderCellTemplate(@<text>Price</text>);
            })
        )
</div>


