@model ERPKeeperCore.Enterprise.Models.Items.Brand


<div id="treeList" class="">

    @(Html.DevExtreme().DataGrid<ERPKeeperCore.Enterprise.Models.Items.Item>()
    .ID("gridList")
    .KeyExpr("Id")
    
        
    .ShowRowLines(true)
    .ShowBorders(false)
    .Editing(editing => editing.Mode(GridEditMode.Row).AllowUpdating(true)@*
            .AllowDeleting(true)*@
    .AllowAdding(true)
    )
    .Paging(pagging=> pagging.PageSize(100))
    .AllowColumnResizing(true).AllowColumnReordering(true)
    .HeaderFilter(headerFilter => headerFilter.Visible(true).Search(s=>s.Enabled(true)))

    .ColumnAutoWidth(false)
        @*.AutoExpandAll(true)*@
    .RowDragging(rd => rd
    .AllowDropInsideItem(false)
    .AllowReordering(false)
        @*.OnDragChange("onDragChange")
            .OnDragEnd("onDragEnd")
            .ShowDragIcons(false)*@
    )

    .RowAlternationEnabled(true).AllowColumnReordering(true)
    .Columns(columns => {
    columns.Add().DataField("BrandName").Width(130)
    .CellTemplate(new JS("function(container, options) { $('<a>').attr('href', '/Products/Brands/' + options.data.BrandGuid + '/').text(options.data.BrandName).appendTo(container); }"));

    columns.Add().DataField("PartNumber")
    .SortOrder(SortOrder.Asc)
    .SortIndex(1)
    .Width(150)
    .CellTemplate(new JS("function(container, options) { $('<a>').attr('href', '/Products/Items/' + options.data.Id + '/').append($('<span>').addClass('font-weight-600').text(options.data.PartNumber)).appendTo(container); }"));
            columns.AddFor(m => m.Description).MinWidth(250)
    .Width(350)
    .CellTemplate(new JS("function(container, options) { $('<a>').attr('href', '/Products/Items/' + options.data.Id + '/').text(options.data.Description).appendTo(container); }"));
     


    columns.AddFor(m=>m.ItemType).SortOrder(SortOrder.Asc).SortIndex(2).Lookup(lookup => lookup
    .DataSource(Html.GetEnumSelectList<ERPKeeperCore.Enterprise.Models.Items.Enums.ItemTypes>().Select(i => new { Value = int.Parse(i.Value), Text = i.Text}))
    .DisplayExpr("Text")
    .ValueExpr("Value")
    );
      
    columns.AddFor(m => m.AmountOnHand).AllowEditing(false).Width(60).HeaderCellTemplate(new JS("function() { return 'Stock'; }"));
    columns.AddFor(m => m.SoldAmount).Width(60).HeaderCellTemplate(new JS("function() { return 'Sold'; }"));
    columns.Add().DataField("SalePrice").Width(130).Format( Format.FixedPoint ).HeaderCellTemplate(new JS("function() { return 'Price'; }"));

    //columns.Add().DataField("Id");
    })
    )
</div>


